# Local development environment for the marcos backoffice app.
#
# Copy this file to `.env` (same directory) and fill in the values.
# This file is only used for local dev — deployed environments get their
# variables from Vercel project settings.
#
# All variables are read at build time via SvelteKit's `$env/static/private`
# and `$env/static/public`, so:
#   - every variable below must be defined (the build/dev server fails on
#     missing imports),
#   - changes to `.env` require restarting the dev server.
#
# The AWS resources referenced here (tables, buckets, IAM policies) are
# created by the CDK app in `apps/marcos-aws`. See "How to Develop" in the
# root README for the full setup flow. Names below assume the infrastructure
# was deployed with CDK_ENV_NAME=dev.

# ─── Application ─────────────────────────────────────────────────────────────

# Environment label used in tracking and feature-flag resolution.
# The code special-cases "pre" and "prod"; use something else locally.
ENV_NAME=dev

# Git branch name. Vercel provides this automatically in deployments; set it
# manually for local dev. Non-prod feature flags are scoped to this value.
VERCEL_GIT_COMMIT_REF=local

# Primary store identifier (UUID). Must match the MAIN_STORE_ID the CDK
# environment was deployed with, and the storeId in your Auth0 app_metadata.
MAIN_STORE_ID=00000000-0000-0000-0000-000000000000

# Set to "true" to redirect all traffic to /maintenance.
MAINTENANCE_MODE=false

# ─── AWS credentials ─────────────────────────────────────────────────────────

# Access key for an IAM user with the `dev-main-store-read-policy` and
# `dev-main-store-write-policy` managed policies attached (created by CDK).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1

# Separate, narrower credentials for the public order-tracking pages.
# This IAM user should only carry the `dev-public-track-orders-policy`.
# For local dev you can reuse the main credentials if you are not working
# on the public tracking flow.
TRACK_AWS_ACCESS_KEY_ID=
TRACK_AWS_SECRET_ACCESS_KEY=

# ─── DynamoDB tables ─────────────────────────────────────────────────────────
# Created by CDK as `${CDK_ENV_NAME}-<table>`. Schemas are documented in
# packages/marcos-core/docs/database.md

ORDER_TABLE=dev-order-v2
CUSTOMER_TABLE=dev-customer-v2
CALCULATED_ITEM_ORDER_TABLE=dev-calculated-item-order
LIST_PRICING_TABLE=dev-list-pricing-v2
FILE_TABLE=dev-file
CONFIG_TABLE=dev-config
ORDER_SET_TABLE=dev-order-set
ORDER_AUDIT_TRAIL_TABLE=dev-order-audit-trail-v3

# ─── S3 buckets ──────────────────────────────────────────────────────────────
# Created by CDK as `mmss-${CDK_ENV_NAME}-<bucket>`.

MOLD_PRICES_BUCKET=mmss-dev-mold-prices
FILES_BUCKET=mmss-dev-files
REPORTS_BUCKET=mmss-dev-reports

# ─── Authentication (Better Auth + Auth0) ────────────────────────────────────

# Secret used by Better Auth to sign/encrypt session cookies.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=

# Auth0 application credentials. The Auth0 app must have the dev URL
# (http://localhost:5173) in its allowed callback/logout/web origins, and
# users need `storeId` and `priceManager` set in their app_metadata.
AUTH_AUTH0_ID=
AUTH_AUTH0_SECRET=
AUTH_AUTH0_ISSUER=https://<tenant>.eu.auth0.com

# ─── Analytics (PostHog) ─────────────────────────────────────────────────────

# PostHog project API key, used by both client- and server-side tracking.
PUBLIC_POSTHOG_KEY=

# Optional reverse-proxy host for client-side PostHog (api_host). Leave empty
# to disable the proxy.
PUBLIC_POSTHOG_PROXY=

# Set both to "true" locally so your activity doesn't pollute analytics
# (tracking falls back to a no-op implementation).
TRACKING_DISABLED=true
PUBLIC_TRACKING_DISABLED=true
