{
	"name": "mmss-app",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"lint": "turbo lint",
		"update-packages": "bunx npm-check-updates -u --workspaces && bun i",
		"skills": "bunx skills experimental_install",
		"format": "prettier --write \"**/*.{ts,tsx,md}\""
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"bun": {
		"overrides": {
			"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
		}
	},
	"devDependencies": {
		"@tsconfig/node24": "24.0.4",
		"eslint": "10.4.0",
		"prettier": "3.8.3",
		"prettier-plugin-svelte": "4.0.1",
		"prettier-plugin-tailwindcss": "0.8.0",
		"turbo": "^2.9.14",
		"typescript": "6.0.3"
	},
	"packageManager": "bun@1.3.14"
}
